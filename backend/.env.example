ELEVEN_API_KEY=
SMALLEST_API_KEY=
NIM_API_KEY=
NIM_LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
NIM_CHAT_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
NIM_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
NIM_PII_MODEL=nvidia/gliner-pii
NIM_RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
