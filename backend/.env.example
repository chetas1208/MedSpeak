ENABLE_QA_AGENT_LLM=false
REQUEST_TIMEOUT_SECONDS=90
WORKER_POLL_SECONDS=0.5
WORKER_CONCURRENCY=1
ALLOWED_ORIGINS=http://localhost:3000
DATA_DIR=./data
LOG_LEVEL=INFO
